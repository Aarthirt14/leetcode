# Problem: Longest Consecutive Sequence
# Platform: LeetCode
# Pattern: Arrays + Hashing (Set)
# Difficulty: Medium
#
# Key Idea:
# - Use a set for O(1) lookup
# - Only start counting when (num - 1) is NOT present
# - Expand forward using (current + 1)
#
# Time Complexity: O(n)
# Space Complexity: O(n)
#
# Why this works:
# - Avoids re-counting sequences
# - Each number is processed once

from typing import List

class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        num_set = set(nums)
        longest = 0

        for num in num_set:
            # Check if it's the start of a sequence
            if num - 1 not in num_set:
                current = num
                length = 1

                # Expand the sequence
                while current + 1 in num_set:
                    current += 1
                    length += 1

                longest = max(longest, length)

        return longest
